{
  "name": "pos-it",
  "version": "1.0.0",
  "description": "POS-it: Professional Point of Sale System (Electron + Vite + React)",
  "author": "ZSE",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env ELECTRON_RUN_AS_NODE=0 NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder --win --ia32",
    "build-win": "vite build && electron-builder --win",
    "build-win32": "vite build && electron-builder --win --ia32",
    "build-all": "vite build && electron-builder --win --ia32",
    "start": "vite build && cross-env ELECTRON_RUN_AS_NODE=0 electron .",
    "preview": "vite preview"
  },
  "postinstall": "electron-builder install-app-deps",
  "build": {
    "appId": "com.zse.pos",
    "productName": "POS-it System",
    "directories": {
      "output": "dist-app",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json",
      "main.js",
      "preload.js"
    ],
    "asar": true,
    "npmRebuild": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "certificateFile": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ZSE POS System",
      "differentialPackage": true
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "core-js-pure": "^3.48.0",
    "dotenv": "^16.3.1",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.8.0",
    "sql.js": "^1.14.0",
    "twilio": "^4.10.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  }
}
